{
  "name": "quizcraft-backend",
  "version": "2.0.0",
  "description": "QuizCraft Backend — Express + MongoDB + Groq AI (all-in-one)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev":        "node --watch src/index.js",
    "start":      "node src/index.js",
    "dev:memory": "USE_MEMORY_DB=true node --watch src/index.js",
    "seed":       "node src/scripts/seed.js",
    "setup":      "node setup.js"
  },
  "dependencies": {
    "bcryptjs":            "^2.4.3",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "express":             "^4.19.2",
    "groq-sdk":            "^0.7.0",
    "jsonwebtoken":        "^9.0.2",
    "mongoose":            "^8.7.0",
    "mongodb-memory-server": "^10.1.2"
  }
}
